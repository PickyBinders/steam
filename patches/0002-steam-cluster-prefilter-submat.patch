+// STEAM patch: when MMSEQS_PREFILTER_SUBMAT is set, swap par.scoringMatrixFile
+// around prefilter param string generation so the k-mer prefilter uses the TEA
+// matrix while gapped alignment keeps the AA matrix.
+static const char *steamPrefilterSubMat() {
+    return getenv("MMSEQS_PREFILTER_SUBMAT");
+}
+#define STEAM_SWAP_PREFILTER_SUBMAT(par, saved) \
+    do { const char *_m = steamPrefilterSubMat(); if (_m) { saved = par.scoringMatrixFile; par.scoringMatrixFile = MultiParam<NuclAA<std::string>>(NuclAA<std::string>(_m, _m)); } } while (0)
+#define STEAM_RESTORE_PREFILTER_SUBMAT(par, saved) \
+    do { if (steamPrefilterSubMat()) { par.scoringMatrixFile = saved; } } while (0)
+
